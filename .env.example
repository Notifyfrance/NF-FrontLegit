# API URL - Production
VITE_API_URL=https://api.nf-legit.me

# Pour dev local avec backend local, utiliser:
# VITE_API_URL=http://localhost:3000

# Discord — utilisé par le CTA "Ouvrir un deal" sur la page Profile
# VITE_DISCORD_GUILD_ID : ID du serveur Discord Notify France (deep link discord.com/channels/{id})
# VITE_DISCORD_DEAL_CHANNEL_ID (optionnel) : ID d'un salon dédié aux deals, pour un deep link plus précis
# VITE_DISCORD_INVITE_URL (optionnel) : URL pour les non-membres (fallback: https://notify-france.fr)
VITE_DISCORD_GUILD_ID=
VITE_DISCORD_DEAL_CHANNEL_ID=
VITE_DISCORD_INVITE_URL=https://notify-france.fr
